{
    "compilerOptions": {
        "typeRoots": ["node_modules/@types"],
        "jsx": "react",
        "lib": ["dom", "es2017"],
        "target": "es5",
        "module": "es6",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strictNullChecks": true
    }
}
